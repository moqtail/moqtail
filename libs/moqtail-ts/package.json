{
  "name": "moqtail",
  "version": "0.8.1",
  "description": "Media Over QUIC Transport client implementation",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "moqtail",
    "moq",
    "media",
    "quic",
    "transport",
    "streaming"
  ],
  "homepage": "https://moqtail.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moqtail/moqtail.git",
    "directory": "libs/moqtail-ts"
  },
  "bugs": {
    "url": "https://github.com/moqtail/moqtail/issues"
  },
  "author": {
    "name": "Streaming University",
    "email": "info@moqtail.dev",
    "url": "https://moqtail.dev"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./model": {
      "import": {
        "types": "./dist/model.d.ts",
        "default": "./dist/model.js"
      },
      "require": {
        "types": "./dist/model.d.cts",
        "default": "./dist/model.cjs"
      }
    },
    "./util": {
      "import": {
        "types": "./dist/util.d.ts",
        "default": "./dist/util.js"
      },
      "require": {
        "types": "./dist/util.d.cts",
        "default": "./dist/util.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsc --noEmit && tsup && api-extractor run",
    "test": "vitest",
    "format": "prettier --check .",
    "test:run": "vitest run",
    "clean": "rimraf dist",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.6",
    "@tsconfig/strictest": "^2.0.8",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
