{
  "type": "module",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "prepare": "node .husky/install.mjs",
    "changeset": "changeset",
    "changeset:release": "npm run build && changeset publish",
    "version": "changeset version && node scripts/postversion.mjs",
    "build": "npm --prefix libs/moqtail-ts run build && npm --prefix apps/client-js run build && npm --prefix apps/meet run build",
    "test": "npm --prefix libs/moqtail-ts run test -- run",
    "format": "npm --prefix libs/moqtail-ts run format && npm --prefix apps/client-js run format && npm --prefix apps/meet run format"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prompts": "^2.4.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "npm@12.0.1",
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
